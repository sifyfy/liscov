{
	"name": "liscov-tauri",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test --config e2e/playwright.config.ts",
		"test:e2e:chat": "playwright test --config e2e/playwright.config.ts e2e/chat-basic.spec.ts e2e/chat-message-types.spec.ts e2e/chat-styling.spec.ts e2e/chat-viewer-panel.spec.ts",
		"test:e2e:auth": "playwright test --config e2e/playwright.config.ts e2e/auth-flow.spec.ts",
		"test:e2e:ws": "playwright test --config e2e/playwright.config.ts e2e/websocket.spec.ts",
		"test:e2e:ci": "playwright test --config e2e/playwright.config.ts --grep-invert @external"
	},
	"devDependencies": {
		"@playwright/test": "^1.57.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.18",
		"@tauri-apps/cli": "^2.9.6",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.0.7",
		"@types/ws": "^8.18.1",
		"jsdom": "^27.4.0",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.2.6",
		"vitest": "^4.0.17",
		"ws": "^8.19.0"
	},
	"dependencies": {
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource/plus-jakarta-sans": "^5.2.8",
		"@fontsource/zen-kaku-gothic-new": "^5.2.7",
		"@tauri-apps/api": "^2.9.1",
		"@tauri-apps/plugin-dialog": "^2.5.0",
		"@tauri-apps/plugin-shell": "^2.3.4",
		"virtua": "^0.48.6"
	}
}
