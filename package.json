{
	"name": "liscov-tauri",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.17.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"lint": "eslint src/",
		"format": "eslint --fix src/",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"secscan": "pnpm audit --prod --audit-level high",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e:build": "npx tsx e2e/scripts/build-for-e2e.ts",
		"test:e2e": "npx tsx e2e/scripts/build-for-e2e.ts && playwright test --config e2e/playwright.config.ts",
		"test:e2e:chat": "playwright test --config e2e/playwright.config.ts e2e/chat-basic.spec.ts e2e/chat-message-types.spec.ts e2e/chat-styling.spec.ts e2e/chat-viewer-panel.spec.ts",
		"test:e2e:auth": "playwright test --config e2e/playwright.config.ts e2e/auth-flow.spec.ts",
		"test:e2e:ws": "playwright test --config e2e/playwright.config.ts e2e/websocket.spec.ts",
		"test:e2e:ci": "playwright test --config e2e/playwright.config.ts --grep-invert @external"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@stryker-mutator/core": "^9.6.1",
		"@stryker-mutator/typescript-checker": "^9.6.1",
		"@stryker-mutator/vitest-runner": "^9.6.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.3.0",
		"@tauri-apps/cli": "^2.11.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.8.0",
		"@types/ws": "^8.18.1",
		"@vitest/coverage-v8": "4.1.6",
		"eslint": "^10.4.0",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"jsdom": "^27.4.0",
		"svelte": "^5.55.7",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^7.3.3",
		"vitest": "^4.1.6",
		"ws": "^8.20.1"
	},
	"dependencies": {
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource/plus-jakarta-sans": "^5.2.8",
		"@fontsource/zen-kaku-gothic-new": "^5.2.7",
		"@tauri-apps/api": "^2.11.0",
		"@tauri-apps/plugin-dialog": "^2.7.1",
		"@tauri-apps/plugin-shell": "^2.3.5",
		"virtua": "^0.48.8"
	}
}
